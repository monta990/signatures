msgid ""
"No hay plantilla cargada para esta configuración. Carga una en la pestaña "
"correspondiente."
msgstr ""
"No template loaded for this configuration. Upload one in the corresponding "
"tab."

msgid ""
"Arrastra cada campo a su posición. Usa los inputs de tamaño para ajustar el "
"tamaño de fuente. Guarda con el botón Guardar."
msgstr ""
"Drag each field to its position. Use size inputs to adjust font size. Save "
"with the Save button."

msgid "Campo"
msgstr "Field"

msgid "Tamaño (px)"
msgstr "Size (px)"

msgid "Posición X / Y"
msgstr "Position X / Y"

msgid "Restaurar posiciones por defecto"
msgstr "Restore default positions"

msgid "Plantilla con celular — Editor de posiciones"
msgstr "Template with mobile — Position editor"

msgid "Plantilla sin celular — Editor de posiciones"
msgstr "Template without mobile — Position editor"

msgid ""
"Hay cambios en las posiciones sin guardar. Haz clic en Guardar para "
"aplicarlos."
msgstr "There are unsaved position changes. Click Save to apply them."

msgid "Guardar"
msgstr "Save"

msgid "No se pudo obtener el usuario actual."
msgstr "Could not retrieve the current user."

msgid "Correo de prueba enviado a %s."
msgstr "Test email sent to %s."

msgid "Firma enviada correctamente a %s."
msgstr "Signature successfully sent to %s."

msgid ""
"No se pudo enviar el correo de prueba. Verifica la configuración de correo "
"saliente en GLPI."
msgstr ""
"Could not send the test email. Check the outgoing mail configuration in "
"GLPI."

msgid ""
"No se pudo enviar el correo. Verifica la configuración de correo saliente en"
" GLPI."
msgstr ""
"Could not send the email. Please check the outgoing mail configuration in "
"GLPI."

msgid "Email Signatures"
msgstr "Email Signatures"

msgid "Configuración incompleta"
msgstr "Incomplete configuration"

msgid "Firma de correo"
msgstr "Email Signature"

msgid "Generar firma para correo"
msgstr "Generate email signature"

msgid "No se encontraron las plantillas."
msgstr "Templates not found."

msgid ""
"Por favor valida que las plantillas existan en la configuración del "
"complemento."
msgstr "Please verify that the templates exist in the plugin configuration."

msgid "El envío por correo no está disponible."
msgstr "Email sending is not available."

msgid ""
"Configura el asunto y cuerpo del correo en la configuración del complemento "
"para habilitarlo."
msgstr ""
"Configure the email subject and body in the plugin settings to enable it."

msgid "Generando firma para: %s"
msgstr "Generating signature for: %s"

msgid "Incluir código QR de WhatsApp"
msgstr "Include WhatsApp QR code"

msgid "Este usuario no tiene número celular, el QR no estará disponible."
msgstr "This user has no mobile number; the QR code will not be available."

msgid "Descargar firma"
msgstr "Download signature"

msgid "Vista previa"
msgstr "Preview"

msgid "Enviar por correo"
msgstr "Send by email"

msgid "Vista previa de firma"
msgstr "Signature preview"

msgid "Generando vista previa..."
msgstr "Generating preview..."

msgid ""
"Las plantillas no están correctamente cargadas validalo en configuración del"
" complemento"
msgstr ""
"Templates are not correctly loaded. Please check the plugin configuration."

msgid "No se encontró la fuente TTF: %s"
msgstr "TTF font not found: %s"

msgid "Extensión GD de PHP es requerida"
msgstr "PHP GD extension is required."

msgid ""
"El código de país para Whatsapp no está configurado. Defínelo en la "
"configuración del complemento."
msgstr ""
"WhatsApp country code is not configured. Define it in the plugin settings."

msgid ""
"El asunto del correo no está configurado. Defínelo en la configuración del "
"complemento."
msgstr "Email subject is not configured. Define it in the plugin settings."

msgid ""
"El cuerpo del correo no está configurado. Defínelo en la configuración del "
"complemento."
msgstr "Email body is not configured. Define it in the plugin settings."

