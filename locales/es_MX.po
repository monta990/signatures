msgstr "Solo el nombre, sin URL ni @"

msgid "Country code for WhatsApp QR"
msgstr "Código de país para QR de Whatsapp"

msgid "Ex: 1"
msgstr "Ej: 52"

msgid ""
"Numeric country code only, no + or spaces. Ex: 1 (USA), used to generate the"
" WhatsApp link in the QR code."
msgstr ""
"Solo el código numérico, sin + ni espacios. Ej: 52 (México), para generar el"
" enlace que lleva a Whatsapp en el QR."

msgid "Email Options"
msgstr "Opciones del correo electrónico"

msgid "Available variables"
msgstr "Variables disponibles"

msgid "bold"
msgstr "negrita"

msgid "italic"
msgstr "cursiva"

msgid "underline"
msgstr "subrayado"

msgid "Click a variable to insert it into the active field."
msgstr "Haz clic en una variable para insertarla en el campo activo."

msgid "Click to insert"
msgstr "Clic para insertar"

msgid "User's full name"
msgstr "Nombre completo del usuario"

msgid "Company name (configured in General settings)"
msgstr "Nombre de la empresa (configurado en General)"

msgid "Today's date in dd/mm/yyyy format"
msgstr "Fecha del día en formato dd/mm/aaaa"

msgid "Email subject"
msgstr "Asunto del correo"

msgid "E.g.: Your corporate email signature"
msgstr "Ej: Tu firma de correo corporativa"

msgid "You can use the variables {nombre}, {empresa} and {fecha}."
msgstr "Puedes usar las variables {nombre}, {empresa} y {fecha}."

msgid "Email body"
msgstr "Cuerpo del correo"

msgid "Bold — **text**"
msgstr "Negrita — **texto**"

msgid "Italic — *text*"
msgstr "Cursiva — *texto*"

msgid "Underline — __text__"
msgstr "Subrayado — __texto__"

msgid ""
"E.g.: Attached you will find your corporate email signature. Save it and use"
" it in your email client."
msgstr ""
"Ej: Adjunto encontrarás tu firma de correo corporativa. Guárdala y úsala en "
"tu cliente de correo."

msgid "Email footer"
msgstr "Pie del correo"

msgid "E.g.: This email was automatically generated by the GLPI system."
msgstr "Ej: Este correo fue generado automáticamente por el sistema GLPI."

msgid "GLPI mail server not configured"
msgstr "Servidor de correo de GLPI no configurado"

msgid "Configure the email subject and body first"
msgstr "Configure el asunto y cuerpo del correo primero"

msgid "Send a test email to your registered GLPI address"
msgstr "Envía un correo de prueba a tu dirección registrada en GLPI"

msgid "Send test email"
msgstr "Enviar correo de prueba"

msgid "The email will be sent to the address registered in your GLPI profile."
msgstr "El correo se enviará a la dirección registrada en tu perfil de GLPI."

