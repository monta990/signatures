msgstr "Error al cargar la vista previa"

msgid "PHP 8.1 or higher is required to install this plugin."
msgstr "Se requiere PHP 8.1 o superior para instalar este complemento."

msgid "The PHP GD extension is required to install this plugin."
msgstr "La extensión GD de PHP es requerida para instalar este complemento."

