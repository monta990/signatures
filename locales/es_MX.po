msgstr "Firmas de correo"

msgid "Incomplete configuration"
msgstr "Configuración incompleta"

msgid "Generate email signature"
msgstr "Generar firma de correo"

msgid "Templates not found."
msgstr "No se encontraron las plantillas."

msgid "Please verify that the templates exist in the plugin configuration."
msgstr ""
"Por favor valida que las plantillas existan en la configuración del "
"complemento."

msgid "Email sending is not available."
msgstr "El envío por correo no está disponible."

msgid ""
"Configure the email subject and body in the plugin settings to enable it."
msgstr ""
"Configura el asunto y cuerpo del correo en la configuración del complemento "
"para habilitarlo."

msgid "Generating signature for: %s"
msgstr "Generando firma para: %s"

msgid "Include WhatsApp QR code"
msgstr "Incluir código QR de WhatsApp"

msgid "This user has no mobile number; the QR code will not be available."
msgstr "Este usuario no tiene número celular, el QR no estará disponible."

