#: inc/user.class.php
msgid "Email Signatures"
msgstr "Signatures de courriel"

#: inc/user.class.php
msgid "Firma de correo"
msgstr "Signature de courriel"

#: inc/user.class.php
msgid "Generar firma para correo"
msgstr "Générer une signature de courriel"

#: inc/user.class.php
msgid "No se encontraron las plantillas."
msgstr "Les modèles sont introuvables."

#: inc/user.class.php
msgid "Por favor valida que las plantillas existan en la configuración del complemento."
msgstr "Veuillez vérifier que les modèles existent dans la configuration du plugin."

#: inc/user.class.php
#, php-format
msgid "Generando firma para: %s"
msgstr "Génération de la signature pour : %s"

#: inc/user.class.php
msgid "El envío por correo no está disponible."
msgstr "L'envoi par courriel n'est pas disponible."

#: inc/user.class.php
msgid "Configura el asunto y cuerpo del correo en la configuración del complemento para habilitarlo."
msgstr "Configurez l'objet et le corps du courriel dans la configuration du plugin pour l'activer."

#: inc/user.class.php
msgid "Incluir código QR de WhatsApp"
msgstr "Inclure le code QR WhatsApp"

#: inc/user.class.php
msgid "Este usuario no tiene número celular, el QR no estará disponible."
msgstr "Cet utilisateur n'a pas de numéro de portable, le code QR ne sera pas disponible."

#: inc/user.class.php
msgid "Descargar firma"
msgstr "Télécharger la signature"

#: inc/user.class.php
msgid "Enviar por correo"
msgstr "Envoyer par courriel"

#: inc/signature.class.php
msgid "Las plantillas no están correctamente cargadas validalo en configuración del complemento"
msgstr "Les modèles ne sont pas correctement chargés. Vérifiez la configuration du plugin."

#: inc/signature.class.php
#, php-format
msgid "No se encontró la fuente TTF: %s"
msgstr "Police TTF introuvable : %s"

#: inc/signature.class.php
msgid "Extensión GD de PHP es requerida"
msgstr "L'extension GD de PHP est requise"

#: inc/signature.class.php
msgid "El código de país para Whatsapp no está configurado. Defínelo en la configuración del complemento."
msgstr "Le code pays WhatsApp n'est pas configuré. Définissez-le dans la configuration du plugin."

#: inc/signature.class.php
msgid "El asunto del correo no está configurado. Defínelo en la configuración del complemento."
msgstr "L'objet du courriel n'est pas configuré. Définissez-le dans la configuration du plugin."

#: inc/signature.class.php
msgid "El cuerpo del correo no está configurado. Defínelo en la configuración del complemento."
msgstr "Le corps du courriel n'est pas configuré. Définissez-le dans la configuration du plugin."

#: inc/signature.class.php
#, php-format
msgid "No se pudo cargar la plantilla: %s"
msgstr "Impossible de charger le modèle : %s"

#: inc/signature.class.php
msgid "Entidad no válida"
msgstr "Entité invalide"

#: inc/signature.class.php
msgid "No especificado"
msgstr "Non spécifié"

#: inc/signature.class.php
msgid "Oficina:"
msgstr "Bureau :"

#: inc/signature.class.php
msgid "Ext:"
msgstr "Poste :"

#: front/send.php
msgid "El usuario no tiene una dirección de correo configurada."
msgstr "L'utilisateur n'a pas d'adresse courriel configurée."

#: front/send.php
#, php-format
msgid "Firma enviada correctamente a %s."
msgstr "Signature envoyée avec succès à %s."

#: front/send.php
msgid "No se pudo enviar el correo. Verifica la configuración de correo saliente en GLPI."
msgstr "Impossible d'envoyer le courriel. Vérifiez la configuration du courrier sortant dans GLPI."

#: front/config.form.php
msgid "Firma de Correo"
msgstr "Signature de courriel"

#: front/config.form.php
msgid "Configuración de firma para correo"
msgstr "Configuration de la signature de courriel"

#: front/config.form.php
msgid "Plantilla con celular eliminada"
msgstr "Modèle avec portable supprimé"

#: front/config.form.php
msgid "Plantilla sin celular eliminada"
msgstr "Modèle sans portable supprimé"

#: front/config.form.php
msgid "Archivo demasiado grande (Máx. 300 KB)"
msgstr "Fichier trop volumineux (Max. 300 Ko)"

#: front/config.form.php
msgid "Formato inválido, solo PNG"
msgstr "Format invalide, PNG uniquement"

#: front/config.form.php
msgid "Configuración guardada correctamente"
msgstr "Configuration enregistrée avec succès"

#: front/config.form.php
msgid "Actual"
msgstr "Actuel"

#: front/config.form.php
msgid "Eliminar"
msgstr "Supprimer"

#: front/config.form.php
msgid "Cargar nueva"
msgstr "Charger un nouveau"

#: front/config.form.php
msgid "Guardar"
msgstr "Enregistrer"

#: front/config.form.php
msgid "Asunto del correo"
msgstr "Objet du courriel"

#: front/config.form.php
msgid "Ej: Tu firma de correo corporativa"
msgstr "Ex : Votre signature de courriel d'entreprise"

#: front/config.form.php
msgid "Título que verá el destinatario en su bandeja de entrada."
msgstr "Titre que le destinataire verra dans sa boîte de réception."

#: front/config.form.php
msgid "Cuerpo del correo"
msgstr "Corps du courriel"

#: front/config.form.php
msgid "Ej: Adjunto encontrarás tu firma de correo corporativa. Guárdala y úsala en tu cliente de correo."
msgstr "Ex : Vous trouverez ci-joint votre signature de courriel d'entreprise. Enregistrez-la et utilisez-la dans votre client de messagerie."

#: front/config.form.php
msgid "Texto principal del correo que acompaña a la firma adjunta."
msgstr "Texte principal du courriel accompagnant la signature en pièce jointe."

#: front/config.form.php
msgid "Pie del correo"
msgstr "Pied de courriel"

#: front/config.form.php
msgid "Ej: Este correo fue generado automáticamente por el sistema GLPI."
msgstr "Ex : Ce courriel a été généré automatiquement par le système GLPI."

#: front/config.form.php
msgid "Texto pequeño al final del correo. Puede usarse para avisos legales o notas adicionales."
msgstr "Petit texte en bas du courriel. Peut être utilisé pour des avis légaux ou des notes supplémentaires."
