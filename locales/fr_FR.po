msgstr "gras"

msgid "italic"
msgstr "italique"

msgid "underline"
msgstr "souligné"

msgid "Click a variable to insert it into the active field."
msgstr "Cliquez sur une variable pour l'insérer dans le champ actif."

msgid "Click to insert"
msgstr "Cliquer pour insérer"

msgid "User's full name"
msgstr "Nom complet de l'utilisateur"

msgid "Company name (configured in General settings)"
msgstr "Nom de l'entreprise (configuré dans Général)"

msgid "Today's date in dd/mm/yyyy format"
msgstr "Date du jour au format jj/mm/aaaa"

msgid "Email subject"
msgstr "Objet du courriel"

msgid "E.g.: Your corporate email signature"
msgstr "Ex. : Votre signature de courriel d'entreprise"

msgid "You can use the variables {nombre}, {empresa} and {fecha}."
msgstr "Vous pouvez utiliser les variables {nombre}, {empresa} et {fecha}."

msgid "Email body"
msgstr "Corps du courriel"

msgid "Bold — **text**"
msgstr "Gras — **texte**"

msgid "Italic — *text*"
msgstr "Italique — *texte*"

msgid "Underline — __text__"
msgstr "Souligné — __texte__"

msgid ""
"E.g.: Attached you will find your corporate email signature. Save it and use"
" it in your email client."
msgstr ""
"Ex. : Ci-joint vous trouverez votre signature de courriel d'entreprise. "
"Enregistrez-la et utilisez-la dans votre client de messagerie."

msgid "Email footer"
msgstr "Pied de courriel"

msgid "E.g.: This email was automatically generated by the GLPI system."
msgstr "Ex. : Ce courriel a été généré automatiquement par le système GLPI."

msgid "GLPI mail server not configured"
msgstr "Serveur de messagerie GLPI non configuré"

msgid "Configure the email subject and body first"
msgstr "Configurez d'abord l'objet et le corps de l'e-mail"

msgid "Send a test email to your registered GLPI address"
msgstr "Envoyer un e-mail de test à votre adresse enregistrée dans GLPI"

msgid "Send test email"
msgstr "Envoyer un e-mail de test"

msgid "The email will be sent to the address registered in your GLPI profile."
msgstr "L'e-mail sera envoyé à l'adresse enregistrée dans votre profil GLPI."

